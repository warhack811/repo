# ═════════════════════════════════════════════════════════════════════════════
# Runa - MASTER ENVIRONMENT TEMPLATE (.env.example)
# ═════════════════════════════════════════════════════════════════════════════
#
# This is the master template for all environment variables used in Runa.
# Use this to create your local .env or .env.local file.
#
# WARNING: NEVER commit your actual .env file with real secrets!
#
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# 1. CORE APPLICATION SETTINGS
# ═════════════════════════════════════════════════════════════════════════════

APP_NAME=Runa
APP_ENV=development
NODE_ENV=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
PORT=3000
SECRET_KEY=your-secret-key-here

# ═════════════════════════════════════════════════════════════════════════════
# 2. DATABASE & PERSISTENCE
# ═════════════════════════════════════════════════════════════════════════════

# Target can be 'local' or 'cloud'
DATABASE_TARGET=local
# Standard PostgreSQL URL
DATABASE_URL=postgresql://runa:password@localhost:5432/runa
# Fallback for local-only setups
LOCAL_DATABASE_URL=postgresql://runa:password@localhost:5432/runa

# Neo4j (Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-key-here

# Redis (Cache & Session Memory)
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ═════════════════════════════════════════════════════════════════════════════
# 3. LLM PROVIDERS & AI GATEWAY
# ═════════════════════════════════════════════════════════════════════════════

# Groq (Primary Provider - https://console.groq.com)
GROQ_API_KEY=your-groq-key-here

# Gemini (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here

# SambaNova (https://cloud.sambanova.ai)
SAMBANOVA_API_KEY=your-sambanova-key-here

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# OpenAI / LM Studio / Compatible APIs
OPENAI_API_KEY=
RUNA_OPENAI_BASE_URL=http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen-9b-vision
LMSTUDIO_API_KEY=lmstudio-local
RUNA_OPENAI_COMPAT_ALLOW_REMOTE=0

# AI Routing Settings
RUNA_DEEPSEEK_MODEL_ROUTER_ENABLED=1
RUNA_MODEL_ROUTER_ENABLED=0

# Serper (Web Search)
SERPER_API_KEY=your-serper-key-here

# ═════════════════════════════════════════════════════════════════════════════
# 4. SUPABASE (Auth & Storage)
# ═════════════════════════════════════════════════════════════════════════════

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=runa-artifacts
SUPABASE_STORAGE_PREFIX=runa

# ═════════════════════════════════════════════════════════════════════════════
# 5. FRONTEND (Vite)
# ═════════════════════════════════════════════════════════════════════════════

VITE_API_URL=http://localhost:8000

# ═════════════════════════════════════════════════════════════════════════════
# 6. DEVELOPER & DEBUG SETTINGS
# ═════════════════════════════════════════════════════════════════════════════

RUNA_DEV_AUTH_ENABLED=0
RUNA_DEV_AUTH_SECRET=
RUNA_DEV_AUTH_EMAIL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
