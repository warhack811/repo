# Production-oriented server env template.
# Keep real secrets in your runtime secret store, not in git.

NODE_ENV=production
PORT=3000

DATABASE_TARGET=cloud
DATABASE_URL=postgresql://user:password@host:5432/runa

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=runa-artifacts
SUPABASE_STORAGE_PREFIX=runa

SAMBANOVA_API_KEY=
DEEPSEEK_API_KEY=
SERPER_API_KEY=

# DeepSeek model economy routing.
# deepseek-v4-flash is used for cheap/balanced work; deepseek-v4-pro is used
# for deep reasoning/tool-heavy work when DeepSeek is selected.
RUNA_DEEPSEEK_MODEL_ROUTER_ENABLED=1
RUNA_MODEL_ROUTER_ENABLED=0

# Local-first vision smoke via LM Studio / OpenAI-compatible API.
# Default is loopback-only. Set RUNA_OPENAI_COMPAT_ALLOW_REMOTE=1 only when
# intentionally switching this OpenAI-compatible endpoint to a trusted cloud gateway.
OPENAI_API_KEY=
RUNA_OPENAI_BASE_URL=http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen-9b-vision
LMSTUDIO_API_KEY=lmstudio-local
RUNA_OPENAI_COMPAT_ALLOW_REMOTE=0

RUNA_DEV_AUTH_ENABLED=0
RUNA_DEV_AUTH_SECRET=
RUNA_DEV_AUTH_EMAIL=
