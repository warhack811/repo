{
	"name": "@runa/types",
	"version": "0.1.0",
	"private": true,
	"description": "Shared type definitions - tum sistemin omurgasi",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
