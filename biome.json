{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			},
			"complexity": {
				"noForEach": "warn",
				"useLiteralKeys": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"files": {
		"ignore": [
			"node_modules",
			".turbo",
			".claude",
			".claire",
			".kilo",
			".codex-screenshots",
			".codex-tmp",
			"**/dist/**",
			"**/dist-electron/**",
			"**/build/**",
			"**/release/**",
			"apps/desktop-agent/temp-asar/**",
			"apps/desktop-agent/electron/main.cjs",
			"apps/desktop-agent/electron/main.js",
			"apps/desktop-agent/electron/preload.cjs",
			"apps/desktop-agent/electron/preload.js",
			"apps/desktop-agent/electron/renderer/App.js",
			"apps/desktop-agent/electron/renderer/App.js.map",
			"apps/web/*.report.json",
			"apps/web/*.report.html",
			"docs/migration/screenshots/**",
			"playwright-report",
			"runa-spike",
			"test-results",
			"*.md",
			"tsconfig*.json",
			"dom.txt",
			"server_logs.txt",
			"scratch_*",
			"scratch*.json",
			"packages/db/check_tables.mjs",
			"packages/db/test_db.mjs",
			"packages/db/test_local_db.mjs",
			"test_loop.mjs",
			"test_ui.mjs"
		]
	}
}
