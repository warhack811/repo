# ═════════════════════════════════════════════════════════════════════════════
# RUNA AI - ORTAM DEĞİŞKENLERİ ŞABLONU (.env)
# ═════════════════════════════════════════════════════════════════════════════
#
# Bu dosya, Runa AI uygulamasının tüm ortam değişkenlerini içerir.
# Geliştirme, test ve üretim ortamları için farklı .env dosyaları kullanılmalıdır.
#
# UYARI: Bu dosya ŞABLONDUR. Kendi anahtarlarınızı buraya yazıp .env olarak kaydedin.
#        Asla gerçek API anahtarlarınızı bu şablon dosyasına commit etmeyin!
#
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# 1. GENEL UYGULAMA AYARLARI
# ═════════════════════════════════════════════════════════════════════════════

APP_NAME=Runa AI
APP_ENV=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_super_secret_key_here

# ═════════════════════════════════════════════════════════════════════════════
# 1.1 FRONTEND (Vite) - API Proxy
# ═════════════════════════════════════════════════════════════════════════════

VITE_API_URL=http://localhost:8000

# ═════════════════════════════════════════════════════════════════════════════
# 2. GROQ API (Ana LLM Provider)
# ═════════════════════════════════════════════════════════════════════════════

GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_BACKUP=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# ═════════════════════════════════════════════════════════════════════════════
# 3. GEMINI API (Yedek LLM Provider)
# ═════════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=your_gemini_api_key_here

# ═════════════════════════════════════════════════════════════════════════════
# 4. REDIS (Cache & Session Memory)
# ═════════════════════════════════════════════════════════════════════════════

REDIS_URL=rediss://default:password@host:port

# ═════════════════════════════════════════════════════════════════════════════
# 5. NEO4J (Graph Memory)
# ═════════════════════════════════════════════════════════════════════════════

NEO4J_URI=neo4j+s://your-neo4j-uri
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ═════════════════════════════════════════════════════════════════════════════
# 6. QDRANT (Vector Memory)
# ═════════════════════════════════════════════════════════════════════════════

QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# ═════════════════════════════════════════════════════════════════════════════
# 7. SERPER (İnternet Arama)
# ═════════════════════════════════════════════════════════════════════════════

SERPER_API_KEY=your_serper_api_key_here
SERPER_ENDPOINT=https://google.serper.dev/search

# ═════════════════════════════════════════════════════════════════════════════
# 8. SUPABASE (Database & Auth)
# ═════════════════════════════════════════════════════════════════════════════

SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_here
SUPABASE_DATABASE_URL=your_supabase_postgres_url_here

# ═════════════════════════════════════════════════════════════════════════════
# 9. CORS & NETWORK
# ═════════════════════════════════════════════════════════════════════════════

CORS_ORIGINS=http://localhost:3000,http://localhost:8000
