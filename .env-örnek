# ═════════════════════════════════════════════════════════════════════════════
# Runa - ORTAM YAPIŞKANDIRILMASI (.env-örnek)
# ═════════════════════════════════════════════════════════════════════════════
#
# Bu dosya, Runa uygulamasının tüm ortam değişkenlerini içerir.
# Geliştirme, test ve üretim ortamları için farklı .env dosyaları kullanılmalıdır.
#
# UYARI: Bu dosya ŞABLONdur. Gerçek API anahtarlarınızı buraya yazmayın!
#        Bu dosyayı .env adıyla kopyalayıp içini doldurun.
#
# ═════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════════════════════
# 1. GENEL UYGULAMA AYARLARI
# ═════════════════════════════════════════════════════════════════════════════

APP_NAME=Runa
APP_ENV=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-here

# ═════════════════════════════════════════════════════════════════════════════
# 1.1 FRONTEND (Vite) - API Proxy
# ═════════════════════════════════════════════════════════════════════════════

VITE_API_URL=http://localhost:8000

# ═════════════════════════════════════════════════════════════════════════════
# 2. LLM PROVIDERS
# ═════════════════════════════════════════════════════════════════════════════

# Groq (https://console.groq.com)
GROQ_API_KEY=your-groq-key-here
GROQ_API_KEY_BACKUP=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# Gemini (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-key-here

# SambaNova (https://cloud.sambanova.ai)
SAMBANOVA_API_KEY=your-sambanova-key-here

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-key-here

# DeepSeek model economy routing.
# DeepSeek secildiginde kisa/basit isler deepseek-v4-flash, derin/tool-heavy
# isler deepseek-v4-pro ile kosar. Tum provider'lar icin global router acmak
# istersen RUNA_MODEL_ROUTER_ENABLED=1 yap.
RUNA_DEEPSEEK_MODEL_ROUTER_ENABLED=1
RUNA_MODEL_ROUTER_ENABLED=0

# Local-first vision smoke via LM Studio / OpenAI-compatible API.
# Varsayilan loopback-only kalir. Uzak OpenAI-compatible gateway'e bilincli
# geciste RUNA_OPENAI_COMPAT_ALLOW_REMOTE=1 yap.
OPENAI_API_KEY=
RUNA_OPENAI_BASE_URL=http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen-9b-vision
LMSTUDIO_API_KEY=lmstudio-local
RUNA_OPENAI_COMPAT_ALLOW_REMOTE=0

# ═════════════════════════════════════════════════════════════════════════════
# 3. REDIS (Cache & Session Memory)
# ═════════════════════════════════════════════════════════════════════════════

REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ═════════════════════════════════════════════════════════════════════════════
# 4. DATABASE & SEARCH
# ═════════════════════════════════════════════════════════════════════════════

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-key-here

# Serper (Search)
SERPER_API_KEY=your-serper-key-here

# ═════════════════════════════════════════════════════════════════════════════
# 5. SUPABASE (Auth & Storage)
# ═════════════════════════════════════════════════════════════════════════════

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=runa-artifacts

# ═════════════════════════════════════════════════════════════════════════════
# 6. OTHER
# ═════════════════════════════════════════════════════════════════════════════

OLLAMA_BASE_URL=http://127.0.0.1:11434
DATABASE_URL=postgresql://user:password@localhost:5432/runa
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
