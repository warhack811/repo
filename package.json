{
	"name": "runa",
	"version": "0.1.0",
	"private": true,
	"description": "Runa — AI çalışma ortağı. Her seferinde sıfırdan başlamaz.",
	"packageManager": "pnpm@9.15.4",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"build": "turbo run build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:e2e": "pnpm build && playwright test",
		"manifesto:check": "node scripts/ci/manifesto-check.mjs",
		"primitive:coverage": "node scripts/ci/primitive-coverage.mjs",
		"style:check": "node scripts/ci/style-check.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.59.1",
		"turbo": "^2.4.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
